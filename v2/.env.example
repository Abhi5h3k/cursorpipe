# ── Required ────────────────────────────────────────────────────────────────────
# Generate at https://cursor.com/settings → API Keys
CURSOR_API_KEY=your_cursor_api_key_here

# ── Server ──────────────────────────────────────────────────────────────────────
CURSORPIPE_HOST=0.0.0.0
CURSORPIPE_PORT=8080

# Optional bearer token. When set every /v1/* request must include:
#   Authorization: Bearer <token>
# Leave empty to disable authentication.
CURSORPIPE_BEARER_TOKEN=

# ── CORS ────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * to allow all.
# Required for browser-based clients (Open WebUI, LobeChat, Chatbot UI).
CURSORPIPE_CORS_ORIGINS=*

# ── Agent defaults ──────────────────────────────────────────────────────────────
CURSORPIPE_MODEL=composer-2.5
CURSORPIPE_WORKSPACE=.

# ── Stateful sessions ───────────────────────────────────────────────────────────
# Idle sessions are evicted after this many minutes.
CURSORPIPE_SESSION_TTL_MINUTES=30

# ── Features ────────────────────────────────────────────────────────────────────
# Request thinking/reasoning from the SDK and surface it in responses.
# Accepted values: off | low | high  (default: off)
#   off  → do not request thinking; discard any thinking tokens
#   low  → request thinking=low; streaming: delta.reasoning_content, non-stream: cursor_metadata.thinking
#   high → request thinking=high; same surfacing as low but more thorough reasoning
# Use GET /v1/models and check cursor_parameters to see which models support thinking.
# Backward compat: CURSORPIPE_EXPOSE_THINKING=true still works and maps to high.
CURSORPIPE_THINKING_LEVEL=off

# ── Logging ─────────────────────────────────────────────────────────────────────
# Controls both Python stdlib and uvicorn log level.
# Accepted values: debug, info, warning, error, critical
CURSORPIPE_LOG_LEVEL=info
